        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(container_memory_working_set_bytes{namespace=~\"$namespace\", pod=~\"$pod\", container!=\"\", container!=\"POD\"}) by (pod) / sum(kube_pod_container_resource_limits{namespace=~\"$namespace\", pod=~\"$pod\", resource=\"memory\"}) by (pod)",
          "legendFormat": "{{ pod }}",
          "refId": "A"
