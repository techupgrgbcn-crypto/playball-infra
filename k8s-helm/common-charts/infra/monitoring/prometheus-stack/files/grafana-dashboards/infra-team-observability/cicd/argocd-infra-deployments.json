{
  "annotations": { "list": [] },
  "description": "인프라 배포 모니터링 - Istio, Monitoring, ArgoCD, Cert-Manager 등",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": false,
      "keepTime": false,
      "tags": [],
      "targetBlank": true,
      "title": "ArgoCD UI",
      "tooltip": "ArgoCD Dashboard",
      "type": "link",
      "url": "https://argocd.goormgb.space"
    },
    {
      "asDropdown": false,
      "icon": "dashboard",
      "includeVars": false,
      "keepTime": true,
      "tags": [],
      "targetBlank": false,
      "title": "서비스 배포",
      "type": "link",
      "url": "/d/argocd-app-deployments"
    }
  ],
  "panels": [
    {
      "datasource": { "type": "datasource", "uid": "-- Dashboard --" },
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 0 },
      "id": 99,
      "options": {
        "code": { "language": "plaintext", "showLineNumbers": false, "showMiniMap": false },
        "content": "## 인프라 배포 모니터링 - Istio, Monitoring Stack, ArgoCD, Cert-Manager 등 클러스터 인프라 컴포넌트",
        "mode": "markdown"
      },
      "type": "text"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 2 },
      "id": 100,
      "title": "인프라 앱 상태",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Synced 상태인 인프라 앱",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "noValue": "연결 안됨",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 3 },
      "id": 10,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [{ "expr": "count(argocd_app_info{sync_status=\"Synced\", name!~\"dev-.*\"}) OR on() vector(0)", "legendFormat": "Synced", "refId": "A" }],
      "title": "Synced",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "OutOfSync 상태인 인프라 앱",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "noValue": "연결 안됨",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 2 }] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 3 },
      "id": 11,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [{ "expr": "count(argocd_app_info{sync_status=\"OutOfSync\", name!~\"dev-.*\"}) OR on() vector(0)", "legendFormat": "OutOfSync", "refId": "A" }],
      "title": "OutOfSync",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Healthy 상태인 인프라 앱",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "noValue": "연결 안됨",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 3 },
      "id": 12,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [{ "expr": "count(argocd_app_info{health_status=\"Healthy\", name!~\"dev-.*\"}) OR on() vector(0)", "legendFormat": "Healthy", "refId": "A" }],
      "title": "Healthy",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Unhealthy 상태인 인프라 앱",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "noValue": "연결 안됨",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 2 }] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 3 },
      "id": 13,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [{ "expr": "count(argocd_app_info{health_status=\"Degraded\", name!~\"dev-.*\"}) OR on() vector(0)", "legendFormat": "Unhealthy", "refId": "A" }],
      "title": "Unhealthy",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "id": 101,
      "title": "인프라별 배포 현황",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "선택된 시간 범위 내 인프라 Sync 성공 횟수",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "mappings": [],
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 8 },
      "id": 20,
      "options": {
        "displayLabels": ["name", "percent"],
        "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "values": ["value", "percent"] },
        "pieType": "donut",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (name) (increase(argocd_app_sync_total{phase=\"Succeeded\", name!~\"dev-.*\"}[$__range]))",
          "legendFormat": "{{ name }}",
          "refId": "A"
        }
      ],
      "title": "인프라별 Sync 횟수",
      "type": "piechart"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "인프라 앱 목록 및 현재 상태",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "inspect": false },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "sync_status" },
            "properties": [
              { "id": "mappings", "value": [{ "options": { "Synced": { "color": "green", "index": 0 }, "OutOfSync": { "color": "yellow", "index": 1 } }, "type": "value" }] },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "health_status" },
            "properties": [
              { "id": "mappings", "value": [{ "options": { "Healthy": { "color": "green", "index": 0 }, "Degraded": { "color": "red", "index": 1 }, "Progressing": { "color": "blue", "index": 2 } }, "type": "value" }] },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 8 },
      "id": 21,
      "options": { "showHeader": true, "cellHeight": "sm", "footer": { "show": false } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "argocd_app_info{name!~\"dev-.*\"}",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "인프라 앱 목록",
      "transformations": [
        { "id": "filterFieldsByName", "options": { "include": { "names": ["name", "sync_status", "health_status"] } } }
      ],
      "type": "table"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 102,
      "title": "에러 로그",
      "type": "row"
    },
    {
      "datasource": "Loki",
      "description": "ArgoCD 에러 로그",
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 27 },
      "id": 31,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": "Loki",
          "editorMode": "code",
          "expr": "{namespace=\"argocd\"} |~ \"level=error|\\\"level\\\":\\\"error\\\"\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "에러 로그",
      "type": "logs"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 35 },
      "id": 103,
      "title": "Git Webhook & Sync",
      "type": "row"
    },
    {
      "datasource": "Loki",
      "description": "GitHub Webhook 수신 로그 (push event)",
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 36 },
      "id": 32,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": "Loki",
          "editorMode": "code",
          "expr": "{namespace=\"argocd\", container=\"argocd-server\"} |~ \"(?i)webhook|received.*event|push.*event|processing.*hook\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Webhook 수신 로그",
      "type": "logs"
    },
    {
      "datasource": "Loki",
      "description": "Sync 완료 로그",
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 42 },
      "id": 33,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": "Loki",
          "editorMode": "code",
          "expr": "{namespace=\"argocd\"} |~ \"(?i)sync.*completed|sync.*succeeded|operation.*completed|Update.*successful\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Sync 완료 로그",
      "type": "logs"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["argocd", "cicd", "infra"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "prometheus" },
        "hide": 0,
        "includeAll": false,
        "label": "데이터소스",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "ArgoCD 인프라 배포",
  "uid": "argocd-infra-deployments",
  "version": 1
}
