        "showHeader": true
      },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "kube_deployment_status_replicas_ready / kube_deployment_spec_replicas", "format": "table", "instant": true, "refId": "A" }],
      "title": "Deployment 상태",
