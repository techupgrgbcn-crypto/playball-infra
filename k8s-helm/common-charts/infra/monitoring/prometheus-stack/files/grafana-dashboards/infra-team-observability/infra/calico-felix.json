        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "avg(max by (instance) (felix_int_dataplane_apply_time_seconds{quantile=\"0.5\"}))", "legendFormat": "P50", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "avg(max by (instance) (felix_int_dataplane_apply_time_seconds{quantile=\"0.9\"}))", "legendFormat": "P90", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "avg(max by (instance) (felix_int_dataplane_apply_time_seconds{quantile=\"0.99\"}))", "legendFormat": "P99", "refId": "C" }
      ],
      "title": "데이터플레인 적용 시간",
