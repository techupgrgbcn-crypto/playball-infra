    {
      "type": "timeseries",
      "title": "Page Views Over Time",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": "Loki",
      "targets": [
        {
          "expr": "count_over_time({app=\"goormgb-frontend\"} |= \"page_view\" [$__interval])",
          "legendFormat": "Page Views",
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "User Actions Over Time",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": "Loki",
      "targets": [
        {
          "expr": "count_over_time({app=\"goormgb-frontend\"} |= \"match_click\" [$__interval])",
          "legendFormat": "Match Click",
          "refId": "A"
        },
        {
          "expr": "count_over_time({app=\"goormgb-frontend\"} |= \"checkout_start\" [$__interval])",
          "legendFormat": "Checkout Start",
          "refId": "B"
        },
        {
          "expr": "count_over_time({app=\"goormgb-frontend\"} |= \"match_tab_change\" [$__interval])",
          "legendFormat": "Tab Change",
          "refId": "C"
