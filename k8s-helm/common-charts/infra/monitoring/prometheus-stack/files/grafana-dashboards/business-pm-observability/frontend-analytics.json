        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": []
      }
    },
    {
      "type": "piechart",
      "title": "Device Type Distribution",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 12 },
      "datasource": "Loki",
      "targets": [
        {
          "expr": "sum by (device_type) (count_over_time({app=\"goormgb-frontend\"} | json | __error__=\"\" [$__range]))",
          "legendFormat": "{{device_type}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "right" },
        "pieType": "pie",
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" } },
        "overrides": []
      }
    },
    {
      "type": "piechart",
      "title": "Login Status",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 12 },
      "datasource": "Loki",
      "targets": [
        {
          "expr": "sum by (is_logged_in) (count_over_time({app=\"goormgb-frontend\"} | json | __error__=\"\" [$__range]))",
          "legendFormat": "{{is_logged_in}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "right" },
        "pieType": "pie",
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" } },
        "overrides": []
      }
    },
    {
      "type": "bargauge",
      "title": "Top Pages",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 12 },
      "datasource": "Loki",
      "targets": [
        {
          "expr": "topk(10, sum by (route) (count_over_time({app=\"goormgb-frontend\"} |= \"page_view\" | json | __error__=\"\" [$__range])))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ],
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Onboarding Funnel",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": "Loki",
      "targets": [
        {
          "expr": "count_over_time({app=\"goormgb-frontend\"} |= \"onboarding_start\" [$__interval])",
          "legendFormat": "Start",
          "refId": "A"
        },
        {
          "expr": "count_over_time({app=\"goormgb-frontend\"} |= \"onboarding_step1_submit\" [$__interval])",
          "legendFormat": "Step 1 Submit",
          "refId": "B"
        },
        {
          "expr": "count_over_time({app=\"goormgb-frontend\"} |= \"onboarding_complete\" [$__interval])",
          "legendFormat": "Complete",
          "refId": "C"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": []
      }
