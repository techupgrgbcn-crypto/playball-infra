    {
      "type": "timeseries",
      "title": "API Errors",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": "Loki",
      "targets": [
        {
          "expr": "count_over_time({app=\"goormgb-frontend\"} |= \"api_error\" [$__interval])",
          "legendFormat": "API Errors",
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "fieldConfig": {
        "defaults": { "color": { "fixedColor": "red", "mode": "fixed" }, "custom": { "lineWidth": 2, "fillOpacity": 20 } },
        "overrides": []
      }
    },
    {
      "type": "logs",
      "title": "Recent Events",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 28 },
      "datasource": "Loki",
      "targets": [
        {
          "expr": "{app=\"goormgb-frontend\"}",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      }
    }
