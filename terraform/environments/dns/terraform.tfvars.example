domain_name = "playball.one"

# Step 1: falseлЎң мӢңмһ‘ (Route53л§Ң мғқм„ұ)
# Step 2: Porkbun NS м„Өм • нӣ„ trueлЎң ліҖкІҪ (ACM мғқм„ұ)
enable_acm = false

# dns/staging terraform apply нӣ„ outputм—җм„ң ліөмӮ¬
# cd staging && terraform output zone_name_servers
staging_zone_name_servers = [
  "ns-xxxx.xxxxx-xx.org",
  "ns-xxxx.xxxxx-xx.co.uk",
  "ns-xxxx.xxxxx-xx.com",
  "ns-xxxx.xxxxx-xx.net",
]

# prod нҷҳкІҪ мғқм„ұ нӣ„ м¶”к°Җ
prod_zone_name_servers = []
